{
  "name": "skillmap",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "start": "npm --prefix apps/api run start",
    "dev:db:start": "powershell -ExecutionPolicy Bypass -File scripts/start-local-postgres.ps1",
    "dev:db:stop": "powershell -ExecutionPolicy Bypass -File scripts/stop-local-postgres.ps1",
    "dev:db:status": "powershell -ExecutionPolicy Bypass -File scripts/status-local-postgres.ps1",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:ml:flask": "python apps/api/run.py",
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "preview:web": "npm --prefix apps/web run preview"
  }
}
